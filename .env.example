# GitHub Actions secrets (scanner) — Settings > Secrets > Actions
# Supabase: Project Settings > Database > Connection string > Session pooler (port 5432)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
# EODHD (eodhd.com > Settings > API token) — All-World plan. The only price
# source: bulk EOD for both exchanges, per-ticker history, symbol directory.
EODHD_API_TOKEN=xxxx
# Google AI Studio (aistudio.google.com) > Get API key — used ONLY by the
# ai-analyst and weekly-review workflows. NEVER commit a real key; GitHub
# encrypted secrets.
GEMINI_API_KEY=AIzaxxxx

# Vercel env vars (web)
# DATABASE_URL=  (same string as above)
DASHBOARD_PASSWORD=choose_a_password

# Optional scanner tuning
# SCAN_MARKETS=US,MY
# SCAN_FORCE=1            # bypass the trading-calendar session check
# SCAN_MIN_PRICE=10       # US liquidity floor
# SCAN_MIN_DOLLAR_VOL=5000000
# SCAN_MY_MIN_DOLLAR_VOL=2000000
# SCAN_MY_MIN_ADR=1.5
# WAREHOUSE_WINDOW_DAYS=420
